{
  "name": "authbridge",
  "version": "1.0.0",
  "description": "极简 Express 应用，对接 CAS 并生成各种JWT",
  "main": "server.js",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  ],
  "homepage": "https://github.com/Mine-Jufe/AuthBridge",
  "scripts": {
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --watch",
    "generate:rsa": "node scripts/rsa_generate.js",
    "generate:aes": "node scripts/aes_generate.js",
    "generate:jwt": "node scripts/jwt_generate.js",
    "generate:ecc": "node scripts/ecc_generate.js",
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "keywords": [
    "cas",
    "jwt",
    "express",
    "sso"
  ],
  "contributors": [
    {"name": "Mine_JUFE", "url": "https://www.minejufe.cn"},
    {"name": "Tobby_000", "url": "https://www.komonmc.cn"}
   ],
  "dependencies": {
    "axios": "^1.6.0",
    "connect-redis": "^7.1.1",
    "connect-cas2": "^1.2.5",
    "dotenv": "^16.0.0",
    "ejs": "^5.0.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-ejs": "^1.0.3",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
}
