# 服务器配置
PORT=3000
NODE_ENV=development

# CAS 配置
CAS_BASE_URL=https://cas.your-university.edu/cas
CAS_SERVICE_URL=http://localhost:3000/callback

# JWT 配置
JWT_SECRET=your-very-strong-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# 会话配置
SESSION_SECRET=your-session-secret-change-this

# 回调应用配置
CALLBACK_APP_1=http://app1.example.com/auth/callback
CALLBACK_APP_2=http://app2.example.com/auth/callback