# ========== 基础配置 ==========
NODE_ENV=production
PORT=3000
APP_NAME=AuthBridge
APP_URL=http://localhost:3000

# ========== 安全开关 ==========
# 调试接口默认关闭，仅建议在本地短时开启
ENABLE_DEBUG_API=false

# ========== CAS 服务端配置 ==========
CAS_BASE_URL=https://cas.your-university.edu/cas
CAS_VERSION=3.0
# 可选：默认使用 APP_URL，可按需覆盖
# CAS_SERVICE_URL=http://localhost:3000
# 可选：登录目标参数名，默认 service（兼容 target）
# CAS_REDIRECT_KEY=service
CAS_VALIDATE_PATH=/cas/serviceValidate
CAS_TIMEOUT_MS=10000

# ========== JWT 配置 ==========
JWT_EXPIRES_IN=1h

# ========== Session 配置 ==========
SESSION_NAME=authbridge.sid
SESSION_TTL_MS=600000

# ========== 上层回调地址 ==========
CALLBACK_APP_1=http://app1.example.com/auth/callback
CALLBACK_APP_2=http://app2.example.com/auth/callback

# ========== 兼容回退（可选） ==========
# 若 applist.json 不存在，则回退读取此项
WHITELISTED_APPS=app1,app2

# ========== 兼容回退（可选） ==========
# 若 secret.json 不存在，则回退读取这些值
# APP_KEY=authbridge-jufe
# JWT_SECRET=replace-with-strong-secret
# SESSION_SECRET=replace-with-strong-secret