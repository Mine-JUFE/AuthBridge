<p><%= t('callback.body1') %></p>
<p><%= t('callback.body2') %></p>

<form id="callback-form" method="POST" action="<%= callbackUrl %>">
  <input type="hidden" name="token" value="<%= token %>" />
  <button
    id="callback-submit"
    type="submit"
    class="inline-block px-6 py-3 text-white rounded-lg hover:opacity-90 transition duration-300"
    style="
      background-color: color-mix(
        in oklab,
        var(--colors-light-primary) var(--un-text-opacity),
        transparent
      );
    "
  >
    <%= t('callback.continue') %>
  </button>
</form>

<script src="<%= withBasePath('/scripts/auto-post-token.js') %>"></script>
