<p><%= t('error.general.body1') %></p>
<p><%= t('error.general.body2') %></p>
<p><%= t('error.general.body3') %></p>
<% if (detail) { %>
<p class="text-sm text-gray-500"><%= t('error.general.detailPrefix') %> <%= detail %></p>
<% } %>
<a
  href="<%= withBasePath('/') %>"
  class="inline-block px-6 py-3 text-white rounded-lg hover:opacity-90 transition duration-300"
