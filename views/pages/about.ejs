<div class="mx-auto w-11/12 sm:w-4/5 md:w-3/5 text-center">
  <!-- 简介段落 -->
  <p class="mb-8 text-lg leading-relaxed text-gray-700">
    <%= t('about.long.intro') %>
  </p>

  <!-- 功能特点标题 -->
  <h2 class="text-3xl font-bold mb-8 text-gray-900"><%= t('about.long.featuresTitle') %></h2>

  <!-- 功能特点说明 -->
  <div class="space-y-6 mb-10 text-left">
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature1Html') %></p>
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature2Html') %></p>
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature3Html') %></p>
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature4Html') %></p>
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature5Html') %></p>
    <p class="text-gray-700 leading-relaxed"><%- t('about.long.feature6Html') %></p>
  </div>

  <h2 class="text-3xl font-bold mb-8 text-gray-900"><%= t('about.long.termsTitle') %></h2>
  <p class="mb-8 text-lg leading-relaxed text-gray-700"><%= t('about.long.termsIntro') %></p>
  <div class="space-y-6 mb-10 text-left">
    <div class="space-y-6 mb-10 text-left">
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.termCasHtml') %></p>
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.termJwtHtml') %></p>
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.termEccHtml') %></p>
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.termAesHtml') %></p>
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.crackDifficultyHtml') %></p>
      <p class="text-gray-700 leading-relaxed"><%- t('about.long.cryptoTypesHtml') %></p>
    </div>
  </div>

  <!-- 项目开发者标题 -->
  <h2 class="text-3xl font-bold mb-8 text-gray-900"><%= t('about.long.teamTitle') %></h2>
  <p class="mb-8 text-lg leading-relaxed text-gray-700"><%= t('about.long.teamThanks') %></p>

  <!-- 团队与个人信息 -->
  <div class="space-y-8 text-left mb-10 text-center">
    <!-- 团队介绍 -->
    <div>
      <h3 class="text-xl font-semibold mb-2 text-gray-800"><%= t('about.long.devTeamTitle') %></h3>
      <p class="text-gray-700 mb-3"><%- t('about.long.devTeamDesc1Html') %></p>
      <p class="text-gray-700 mb-3"><%= t('about.long.devTeamDesc2') %></p>
      <div class="text-gray-600 space-x-4">
        <a href="https://github.com/Mine-JUFE" target="_blank" class="hover:underline incontext-link">GitHub</a>
        <span class="text-gray-400">|</span>
        <a href="https://www.minejufe.cn" target="_blank" class="hover:underline incontext-link"><%= t('about.long.website') %></a>
      </div>
    </div>

    <!-- 个人开发者 -->
    <div>
      <h3 class="text-xl font-semibold mb-2 text-gray-800"><%= t('about.long.coreDeveloperTitle') %></h3>
      <p class="text-gray-700 mb-3"><%- t('about.long.coreDeveloperDesc1Html') %></p>
      <p class="text-gray-700 mb-3"><%= t('about.long.coreDeveloperDesc2') %></p>
      <div class="text-gray-600 space-x-4">
        <a href="https://github.com/Tobby-000" target="_blank" class="hover:underline incontext-link">GitHub</a>
        <span class="text-gray-400">|</span>
        <a href="https://www.komonmc.cn" target="_blank" class="hover:underline incontext-link"><%= t('about.long.blog') %></a>
      </div>
    </div>
  </div>

  <!-- 项目信息 -->
  <div class="space-y-6 text-left mb-10 text-center">
    <!-- 运维信息 -->
    <div>
      <h3 class="text-xl font-semibold mb-2 text-gray-800"><%= t('about.long.opsTitle') %></h3>
      <p class="text-gray-700"><%= t('about.long.opsTeam') %></p>
      <p class="text-gray-700"><%= t('about.long.opsLocation') %></p>
    </div>

    <!-- 项目地址 -->
    <div>
      <h3 class="text-xl font-semibold mb-2 text-gray-800"><%= t('about.long.repoTitle') %></h3>
      <p class="text-gray-700">
        <%= t('about.long.repoLabel') %>
        <a href="https://github.com/Mine-JUFE/AuthBridge" target="_blank" class="hover:underline incontext-link">github.com/Mine-JUFE/AuthBridge</a>
      </p>
    </div>
  </div>

  <!-- 联系信息 -->
  <div class="pt-6 border-t border-gray-200">
    <p class="text-gray-600"><%= t('about.long.contact') %></p>
  </div>
</div>
