<!DOCTYPE html>
<html lang="<%= htmlLang %>">
  <!-- 引入公共头部 -->
  <%- include('./head'); %>

  <body data-base-path="<%= basePath %>">
    <div id="app" class="page-wrap">
    <%- include('./nav'); %>

      <main class="flex flex-col items-center justify-center gap-6 pt-24">
        <div class="color-light-primary h-12rem w-16rem dark:color-dark-primary">
          <img   
            type="image/svg+xml" 
            src="<%= withBasePath('/icons/logo.svg') %>"
            >
        </div>

        <section class="title-block">
          <h1 class="text-light-onSurface dark:text-dark-onSurface font-serif">
            <%= t(maintitle) %>
          </h1>
          <p
            class="text-light-onSurfaceVariant dark:text-dark-onSurfaceVariant"
          >
            <%= t(secondtitle, typeof secondtitleParams === 'object' ? secondtitleParams : {}) %>
          </p>
        </section>
        <%- body %>
      </main>
    </div>

    <%- include('footer') %>
  </body>
</html>
