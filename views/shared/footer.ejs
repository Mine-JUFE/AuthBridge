<footer class="mt-12 pt-8 pb-6 border-t border-gray-200 dark:border-gray-700">
  <div class="mx-auto w-11/12 sm:w-4/5 md:w-3/5">
    <div class="text-center text-gray-600 dark:text-gray-400 text-sm">
      <!-- 版权信息 -->
      <p class="mb-2">
        <%= t('footer.copyright', { year: new Date().getFullYear() }) %> <a href="https://www.komonmc.cn" target="_blank" class="hover:underline incontext-link">Tobby_000</a>. <%= t('footer.rights') %>
      </p>

      <!-- 免责声明 -->
      <div class="mb-3 text-xs leading-relaxed">
        <p class="mb-1"><%= t('footer.disclaimer1') %></p>
        <p><%= t('footer.disclaimer2') %></p>
      </div>

      <!-- 项目信息 -->
      <div class="text-xs text-gray-500 dark:text-gray-500 mt-3">
        <p>
          <% if (currentLanguage === 'en') { %>
            <%= t('footer.maintainedByPrefix') %>
            <a
              href="https://github.com/Mine-JUFE"
              target="_blank"
              class="hover:underline incontext-link"
            >Mine-JUFE Team</a>
          <% } else { %>
            <a
              href="https://github.com/Mine-JUFE"
              target="_blank"
              class="hover:underline incontext-link"
            >Mine-JUFE 团队 </a><%= t('footer.maintainedBySuffix') %>
          <% } %>
        </p>
      </div>
    </div>
  </div>
</footer>
